{
  "name": "api",
  "version": "1.0.0",
  "description": "Invy API built with Fastify",
  "type": "module",
  "main": "app.ts",
  "scripts": {
    "dev:before": "docker compose up -d",
    "dev": "npm run dev:before && node --experimental-strip-types --env-file-if-exists=.env --watch server.ts",
    "start": "node --experimental-strip-types --env-file-if-exists=.env server.ts",
    "test": "node --experimental-strip-types --test 'test/**/*.test.ts'",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.33.0",
  "directories": {
    "test": "test"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1016.0",
    "@aws-sdk/lib-storage": "^3.1016.0",
    "@clerk/fastify": "^3.1.5",
    "@fastify/autoload": "^6.0.0",
    "@fastify/cors": "^11.2.0",
    "@fastify/env": "^5.0.3",
    "@fastify/multipart": "^9.4.0",
    "@fastify/sensible": "^6.0.0",
    "@invy/db": "workspace:*",
    "@invy/storage": "workspace:*",
    "bullmq": "^5.71.1",
    "drizzle-orm": "^0.45.1",
    "exceljs": "^4.4.0",
    "fastify": "^5.0.0",
    "fastify-plugin": "^5.0.0",
    "ioredis": "^5.10.1",
    "ulid": "^3.0.2"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "drizzle-kit": "^0.31.10",
    "typescript": "^6.0.2"
  }
}